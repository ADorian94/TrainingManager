<?xml version="1.0" encoding="UTF-8"?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui" 
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:TrainingManager.Themes"
             x:Class="TrainingManager.View.Controls.CardWithTextEntry"
             x:Name="this">
    <ContentView.Resources>
        <local:DarkTheme/>
    </ContentView.Resources>
    <Frame Margin="15, 5" Style="{StaticResource CardFrame}">
        <StackLayout BackgroundColor="Transparent">
            <Entry Text="{x:Binding Source={x:Reference this}, Path=CardEntry}" Style="{StaticResource CardEntryContent}" Placeholder="{x:Binding Source={x:Reference this}, Path=CardMainText}"/>
        </StackLayout>
    </Frame>
</ContentView>