<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:TrainingManager.Themes"
             x:Class="TrainingManager.View.SettingsPage"
             BackgroundColor="{StaticResource AppBackgroundColor}">
    <ContentPage.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <local:DarkTheme/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </ContentPage.Resources>
    <ContentPage.Content>
        <StackLayout>
            <Label Text="Settings" Style="{StaticResource Title0}" VerticalOptions="StartAndExpand"/>
            <Grid RowDefinitions="auto, auto" VerticalOptions="End">
                <Button Style="{StaticResource RedButton}" Text="Upload image" Command="{Binding UploadImageCommand}"/>
                <Button Style="{StaticResource BlueButton}" Text="Sign out" Command="{Binding SignOutCommand}"/>
            </Grid>
        </StackLayout>
    </ContentPage.Content>
</ContentPage>