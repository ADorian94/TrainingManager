<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:TrainingManager.View.Controls"
             xmlns:local="clr-namespace:TrainingManager.Themes"
             x:Class="TrainingManager.View.OneRepetitionMaximumCalculatedPage">
    <ContentPage.Resources>
        <local:DarkTheme/>
    </ContentPage.Resources>
    <StackLayout>
        <Label Text="Results" Style="{StaticResource Title0}"/>
        <ListView ItemsSource="{Binding RecomendedMaximums}" SeparatorVisibility="None" HasUnevenRows="True" SelectionMode="None">
            <ListView.ItemTemplate >
                <DataTemplate>
                    <ViewCell>
                        <controls:SimpleCard CardMainText="{Binding MethodName}" CardSecondaryText="{Binding MaximumValue}" Margin="15, 5"/>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </StackLayout>
</ContentPage>