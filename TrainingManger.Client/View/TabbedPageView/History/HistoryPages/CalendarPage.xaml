<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:TrainingManager.View.Controls"
             xmlns:local="clr-namespace:TrainingManager.Themes"
             x:Class="TrainingManager.View.TabbedPageView.History.HistoryPages.CalendarPage">
    <ContentPage.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <local:DarkTheme/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </ContentPage.Resources>
    <ContentPage.Content>
        <ScrollView>
            <StackLayout>
                <!--<Label Text="Calendar" Style="{StaticResource Title0}"/>-->
                <controls:SimpleCard
                Margin="15, 5"
                CardMainText="Moved weights"
                CardSecondaryText="{Binding MovedWeightsInTheMonth}"/>
            </StackLayout>
        </ScrollView>
    </ContentPage.Content>
</ContentPage>