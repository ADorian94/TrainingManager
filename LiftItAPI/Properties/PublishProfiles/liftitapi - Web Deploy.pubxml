<Project>
  <PropertyGroup>
    <WebPublishMethod>MSDeploy</WebPublishMethod>
    <ResourceId>/subscriptions/03803cb6-cf27-4d77-b5c0-e1d3e6beee9d/resourceGroups/TrainingManagerWebApi_Resources/providers/Microsoft.Web/sites/liftitapi</ResourceId>
    <ResourceGroup>TrainingManagerWebApi_Resources</ResourceGroup>
    <ApiResourceId>/subscriptions/03803cb6-cf27-4d77-b5c0-e1d3e6beee9d/resourceGroups/TrainingManagerWebApi_Resources/providers/Microsoft.ApiManagement/service/LiftItAPIapiManagementService/apis/LiftItAPIManagement</ApiResourceId>
    <OpenApiDocumentName>v1</OpenApiDocumentName>
    <UpdateApiOnPublish>true</UpdateApiOnPublish>
    <PublishProvider>AzureWebSite</PublishProvider>
    <LastUsedBuildConfiguration>Release</LastUsedBuildConfiguration>
    <LastUsedPlatform>Any CPU</LastUsedPlatform>
    <SiteUrlToLaunchAfterPublish>https://liftitapi.azurewebsites.net</SiteUrlToLaunchAfterPublish>
    <LaunchSiteAfterPublish>true</LaunchSiteAfterPublish>
