<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:TrainingManager.View.Styles"
             xmlns:controls="clr-namespace:TrainingManager.View.Controls"
             xmlns:converter="clr-namespace:TrainingManager.ViewModel"
             x:Class="TrainingManager.View.WeightWorkout.WeightHistory.HistoryView"
             Title="History">
    <ContentPage.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <local:Style/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </ContentPage.Resources>
    <StackLayout>
        <ListView x:Name="WorkoutList" ItemsSource="{Binding WeightWorkoutsHistory}" SeparatorVisibility="None" HasUnevenRows="True" SelectionMode="None" Margin="0,5,0,0" >
            <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <controls:LowSimpleCard CardMainText="{Binding WorkoutName}" CardFrameTapped="{Binding BindingContext.OpenWorkoutDetailsCommand, Source={x:Reference WorkoutList}}" CardFrameTappedParameter="{Binding WorkoutIdString}" IsButtonVisible="false" />
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </StackLayout>
</ContentPage>